# Auto-detectar archivos de texto y normalizar line endings
* text=auto

# Forzar LF en archivos de código
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf

# Evitar merge manual del lockfile — siempre regenerar con npm install
package-lock.json merge=ours

# Tratar imágenes como binarios
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg binary
*.ico binary
